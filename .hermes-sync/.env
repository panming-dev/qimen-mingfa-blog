# Directus CMS Configuration
# Authentication: Email + Password (OAuth2 login)
DIRECTUS_URL=https://qimendunjia.onrender.com
DIRECTUS_EMAIL=nx.wshuai@gmail.com
DIRECTUS_PASSWORD=yqgbqp4J.G9yAUP

# Collections
POST_COLLECTION=blog_posts
TAGS_COLLECTION=blog_tags
POST_TAGS_JUNCTION=blog_posts__tags

# Migration Settings
MIGRATION_ID=2026-04-blog-migration
BATCH_SIZE=50
THROTTLE_DELAY=1000
MAX_RETRIES=3
CHECKPOINT_INTERVAL=10

# Source Data Paths (space-separated)
SOURCE_PATHS=/tmp/book_chapters_1 /tmp/book_chapters_2

# Optional: Default date for articles without source date
DEFAULT_DATE=2024-01-01

# Canonical URL for blog posts (matches hugo.toml canonicalURL)
# Used to construct absolute URLs in Directus content
CANONICAL_URL=https://panma.site/blog

# Directus User UUID for author field (required for blog_posts)
AUTHOR_ID=e51ecbce-e34f-45d6-b863-030511108267

# Optional: Category ID (if not set, will auto-create "奇门遁甲")
# CATEGORY_ID=

# Logging
LOG_LEVEL=info
LOG_FILE=migration.log

# Dry run mode (true/false) - set to true for testing without actual import
DRY_RUN=false
